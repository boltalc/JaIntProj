class Arith{
    public static int add(int a, int b){
	return a + b;
    }

    public static int sub(int a, int b){
	return a - b;
    }

    public static int multi(int a, int b){
	return a * b;
    }

    public static double divi(int a, int b){
	if(a == 0 || b == 0)
	    return 0;
	else
	    return a / b;
    }
}
